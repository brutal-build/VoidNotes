{
  "name": "void-notes",
  "productName": "Void Notes",
  "version": "0.1.0",
  "description": "Second-brain notatnik Markdown oparty o Electron + React + CodeMirror 6",
  "main": "dist-electron/main.js",
  "author": "brutal-build",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brutal-build/VoidNotes.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "start": "electron .",
    "preview": "vite preview",
    "dist": "npm run build && npx electron-builder --win",
    "dist:win": "npm run build && npx electron-builder --win --publish never",
    "dist:publish": "npm run build && npx electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.pixelcodegh.VoidNotes",
    "productName": "Void Notes",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Void Notes"
    }
  },
  "devDependencies": {
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^35.7.5",
    "electron-builder": "^23.6.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/language": "^6.11.0",
    "@codemirror/search": "^6.5.10",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.5",
    "@replit/codemirror-vim": "^6.3.0",
    "@uiw/react-codemirror": "^4.23.12",
    "gray-matter": "^4.0.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  }
}
