{
  "name": "void-notes",
  "productName": "Void Notes",
  "version": "0.3.0",
  "description": "Second-brain notatnik Markdown oparty o Electron + React + CodeMirror 6",
  "main": "dist-electron/electron/main.js",
  "author": "brutal-build",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brutal-build/VoidNotes.git"
  },
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "dev:vite": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "start": "electron .",
    "preview": "vite preview",
    "dist": "npm run build && npx electron-builder --win",
    "dist:win": "npm run build && npx electron-builder --win --publish never",
    "dist:publish": "npm run build && npx electron-builder --win --publish always",
    "test": "npx -y node@22 node_modules/vitest/vitest.mjs run",
    "test:watch": "npx -y node@22 node_modules/vitest/vitest.mjs",
    "test:coverage": "npx -y node@22 node_modules/vitest/vitest.mjs run --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"electron/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"electron/**/*.ts\"",
    "lint": "eslint src/ electron/"
  },
  "build": {
    "appId": "com.pixelcodegh.VoidNotes",
    "productName": "Void Notes",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "icon.ico",
        "to": "icon.ico"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "brutal-build",
      "repo": "VoidNotes"
    },
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Void Notes"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-force": "^3.0.10",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.3",
    "cross-env": "^10.1.0",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "electron-log": "^5.4.4",
    "eslint": "^9.39.5",
    "jsdom": "^27.0.1",
    "prettier": "^3.9.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.3.5",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/language": "^6.11.0",
    "@codemirror/search": "^6.5.10",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.5",
    "@replit/codemirror-vim": "^6.3.0",
    "@uiw/react-codemirror": "^4.23.12",
    "d3-force": "^3.0.0",
    "electron-updater": "^6.8.9",
    "gray-matter": "^4.0.3",
    "mermaid": "^11.16.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.14"
  }
}
